#!/bin/bash
set -e
echo "Patching AssetsModule into project..."
mkdir -p src/assets/dto

python3 -c "import base64; open('src/assets/dto/create-asset.dto.ts','wb').write(base64.b64decode(''))"
echo "  ✓ src/assets/dto/create-asset.dto.ts"

python3 -c "import base64; open('src/assets/assets.service.ts','wb').write(base64.b64decode(''))"
echo "  ✓ src/assets/assets.service.ts"

python3 -c "import base64; open('src/assets/assets.controller.ts','wb').write(base64.b64decode(''))"
echo "  ✓ src/assets/assets.controller.ts"

python3 -c "import base64; open('src/assets/assets.module.ts','wb').write(base64.b64decode(''))"
echo "  ✓ src/assets/assets.module.ts"

python3 -c "import base64; open('src/app.module.ts','wb').write(base64.b64decode(''))"
echo "  ✓ src/app.module.ts"

echo ""
echo "AssetsModule files created. Running npm install..."
npm install
echo "Done! Start server: npm run start:dev"
