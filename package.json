// =============================================================================
// src/common/interceptors/logging.interceptor.ts
// Logs every request with method, path, statusCode, duration, and tenant.
// =============================================================================
import {
  CallHandler,
  ExecutionContext,
  Injectable,
  Logger,
  NestInterceptor,
} from '@nestjs/common';
import { Observable } from 'rxjs';
import { tap } from 'rxjs/operators';
import { Request, Response } from 'express';

@Injectable()
export class LoggingInterceptor implements NestInterceptor {
  private readonly logger = new Logger('HTTP');

  intercept(context: ExecutionContext, next: CallHandler): Observable<unknown> {
    const request  = context.switchToHttp().getRequest<Request>();
    const response = context.switchToHttp().getResponse<Response>();
    const start    = Date.now();

    const tenant = request.tenantContext?.schemaName ?? 'public';
    const user   = request.tenantContext?.userId ?? 'anon';

    return next.handle().pipe(
      tap({
        next: () => {
          const ms = Date.now() - start;
          this.logger.log(
            `${request.method} ${request.path} ${response.statusCode} ${ms}ms | tenant=${tenant} user=${user}`,
          );
        },
        error: (err) => {
          const ms = Date.now() - start;
          this.logger.warn(
            `${request.method} ${request.path} ${err?.status ?? 500} ${ms}ms | tenant=${tenant} user=${user}`,
          );
        },
      }),
    );
  }
}
